{
  "compilerOptions": {
    /* 🔹 BASIC SETUP */
    "module": "commonjs",
    "target": "ES2023",
    "moduleResolution": "node",

    /* 🔹 OUTPUT */
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",

    /* 🔹 TYPE CHECKING (IMPORTANT 🔥) */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* 🔹 DECORATORS (NestJS REQUIRED) */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    /* 🔹 INTEROP */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* 🔹 PERFORMANCE */
    "skipLibCheck": true,
    "incremental": true,

    /* 🔹 DEBUGGING */
    "sourceMap": true,
    "declaration": true,

    /* 🔹 SAFETY */
    "forceConsistentCasingInFileNames": true
  },

  /* 🔥 VERY IMPORTANT (fixes your issue) */
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
